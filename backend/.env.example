# ====================================================
# CuartoYa — Variables de entorno Backend
# Copia este archivo como .env y completa los valores
# ====================================================

# --- BASE DE DATOS ---
DATABASE_URL=postgresql://cuartoya_user:cuartoya_pass@localhost:5432/cuartoya_db
REDIS_URL=redis://localhost:6379/0

# --- SEGURIDAD JWT ---
SECRET_KEY=REEMPLAZAR_CON_CLAVE_SECRETA_LARGA_Y_SEGURA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CLOUDINARY (Imagenes de habitaciones) ---
# Obtener en: https://cloudinary.com -> Dashboard
CLOUDINARY_CLOUD_NAME=REEMPLAZAR
CLOUDINARY_API_KEY=REEMPLAZAR
CLOUDINARY_API_SECRET=REEMPLAZAR

# --- CULQI (Pagos con tarjeta, Yape, Plin) ---
# Obtener en: https://culqi.com -> Panel de Control
CULQI_PUBLIC_KEY=pk_test_REEMPLAZAR
CULQI_SECRET_KEY=sk_test_REEMPLAZAR

# --- EMAIL (Resend) ---
# Obtener en: https://resend.com -> API Keys
RESEND_API_KEY=re_REEMPLAZAR
EMAIL_FROM=noreply@cuartoya.pe

# --- FIREBASE (Push Notifications Android) ---
# Obtener en: https://console.firebase.google.com -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=REEMPLAZAR
FIREBASE_PRIVATE_KEY=REEMPLAZAR
FIREBASE_CLIENT_EMAIL=REEMPLAZAR

# --- TWILIO WHATSAPP (Opcional, fase 2) ---
# TWILIO_ACCOUNT_SID=REEMPLAZAR
# TWILIO_AUTH_TOKEN=REEMPLAZAR
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- CONFIGURACION APP ---
APP_NAME=CuartoYa
APP_ENV=development
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","exp://localhost:19000"]

# --- SENTRY (Opcional, monitoreo errores) ---
# SENTRY_DSN=REEMPLAZAR
